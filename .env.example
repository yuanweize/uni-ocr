# UniOCR Environment Variables
# Copy this file to .env and adjust as needed.

# API server port (used by docker-compose)
UNIOCR_PORT=8000

# MLX-VLM server URL (leave empty for auto-detection on Apple Silicon)
UNIOCR_MLX_VLM_URL=

# MLX-VLM model identifier
UNIOCR_MLX_VLM_MODEL=PaddlePaddle/PaddleOCR-VL-1.6
